---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SITE } from "../content/config";

const posts = await getCollection("blog");
posts.sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout title="insert title here">
	<h1 id="site-tit">{SITE.title}</h1>
	<p id="site-des">{SITE.description}</p>

	<div class="grid">
		{
			posts.map((post, index) => {
				const isFeatured = index === 0;
				// for some reason <= does not work.
				// see more https://github.com/withastro/compiler/issues/723
				const showImage = index == 2 || index < 2;

				return (
					<a
						class={`card ${isFeatured ? "featured" : ""}`}
						href={`/${post.slug}/`}
					>
						{showImage && (
							<div class="image-wrapper">
								<img
									src={post.data.image || SITE.defaultImage}
									alt={post.data.title}
								/>
							</div>
						)}

						<div class="content">
							<span class="meta">
								{post.data.date} · {post.data.category}
							</span>

							<h2 id="hp-ptit">{post.data.title}</h2>
							<p id="hp-pdes">{post.data.description}</p>
						</div>
					</a>
				);
			})
		}
	</div>
</Layout>

<footer>
	<p>Diagnostics:</p>
	<small>{"{{.Diagnostics}}"}</small>
</footer>
<style>
	/* Mobile-first grid: 1 column */

	/* updated fonts for homepage */
	#site-tit,
	#site-des,
	#hp-ptit,
	#hp-pdes {
		font-family: "DM Sans", sans-serif;
	}

	#site-tit,
	#hp-ptit {
		font-size: var(--hp-h);
		font-weight: 700;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		border: 1px solid #eee;
		border-radius: 10px;
		overflow: hidden; /* Ensures the image doesn't spill over the rounded corners */
		text-decoration: none;
		color: inherit;
		background: #111111;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.card:hover {
		transform: translateY(-4px);
	}

	.card img {
		object-fit: cover;
	}

	.content {
		padding: 1.5rem;
		flex-grow: 1; /* Pushes content to fill remaining space */
		display: flex;
		flex-direction: column;
	}

	.meta {
		font-size: 0.8rem;
		color: #666;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	h2 {
		margin: 0.5rem 0;
		font-size: 1.25rem;
		line-height: 1.3;
	}

	p {
		font-size: 0.95rem;
		color: #555;
		margin: 0;
		line-height: 1.5;
	}

	footer {
		text-align: left;
		font-size: 0.8em;
		color: #333333;
	}

	/* Desktop & Tablet adjustments */
	@media (min-width: 768px) {
		/* Max 2 columns */
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}

		#site-tit,
		#hp-ptit {
			font-size: var(--hp-h-m);
			font-weight: 600;
		}

		/* Featured Post (Index 0) */
		.featured {
			grid-column: 1 / -1; /* Spans across all columns */
			flex-direction: row; /* Horizontal layout */
			padding: 15px;
		}

		.featured .image-wrapper {
			width: 50%;
			flex-shrink: 0;
		}

		.featured img {
			/* height: 100%; */
		}

		.featured .content {
			justify-content: center; /* Centers the text vertically next to the image */
			padding: 2.5rem;
		}

		.featured h2 {
			font-size: 1.75rem; /* Make the featured title a bit bigger */
		}
	}
</style>
